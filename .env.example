# ============================================================
#  Lead Engine — ООО «Вектор Плюс-Про»
#  Скопируй этот файл в .env и заполни своими значениями
# ============================================================

# --- LLM router: четыре режима работы ---
# РЕЖИМ 1 сейчас: разработка через Codex/подписку, продуктовый backend без внешнего LLM.
# РЕЖИМ 2 локальный тест: backend отвечает через одну бесплатную OpenRouter-модель.
# РЕЖИМ 3 демо для мастера: сервер + OpenRouter + одна бесплатная модель для всех текстовых LLM.
# РЕЖИМ 4 финальный сервер: OpenRouter + разные модели под разные задачи.
LLM_RUNTIME_MODE=local_codex
LLM_PROVIDER=dry_run
# В local_codex локальный пульт агентов не делает реальный LLM-вызов.
AGENT_CONTROL_LIVE_LLM=0
# Для локального теста через бесплатную OpenRouter-модель поставить:
# LLM_RUNTIME_MODE=openrouter_free_test
# LLM_PROVIDER=openrouter
# AGENT_CONTROL_LIVE_LLM=1
# LLM_MODEL_DEMO_FREE=deepseek/deepseek-v4-flash:free
# OPENROUTER_API_KEY=заполнить_локально
# Для демо-сервера поставить:
# LLM_RUNTIME_MODE=demo_server_free
# LLM_PROVIDER=openrouter
# AGENT_CONTROL_LIVE_LLM=1
# LLM_MODEL_DEMO_FREE=deepseek/deepseek-v4-flash:free
# OPENROUTER_API_KEY=заполнить_на_сервере
# Ниже сохранены OpenRouter-маршруты для демо/финального серверного режима.
# Обычные дешевые задачи / бесплатный слой на сервере.
LLM_MODEL_DEFAULT_FREE=deepseek/deepseek-v4-flash:free
# Единая бесплатная модель для openrouter_free_test и demo_server_free.
LLM_MODEL_DEMO_FREE=deepseek/deepseek-v4-flash:free
# Управление агентами и постановка задач на сервере.
LLM_MODEL_AGENT_CONTROL=minimax/minimax-2.7
# Разработка, архитектура, сложный дебаг на сервере.
LLM_MODEL_DEVELOPMENT=anthropic/claude-opus-4.7
# Маркетинговые тексты, посты, офферы на сервере.
LLM_MODEL_MARKETING=google/gemini-2.5-flash
# Поиск/ответы по базе знаний после retrieval.
LLM_MODEL_KNOWLEDGE=deepseek/deepseek-v4-flash:free
# Совместимость со старыми агентами.
LLM_MODEL_ANALYSIS=deepseek/deepseek-v4-flash:free
LLM_MODEL_REPLY=minimax/minimax-2.7
LLM_MODEL_CONTENT=google/gemini-2.5-flash
# Важно: если OpenRouter поменял model ID, заменить только значение переменной,
# код агентов менять не нужно.

# --- Voice / image / embeddings routes ---
WHISPER_PROVIDER=local
WHISPER_MODEL=whisper-1
IMAGE_MODEL_PROVIDER=openrouter
IMAGE_MODEL=google/gemini-2.5-flash-image-preview
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001

# --- Claude / Anthropic API ---
# Не обязателен для текущего Codex/dry-run режима; оставлен только как резервный fallback.
ANTHROPIC_API_KEY=

# --- Telegram: бот уведомлений менеджеру (Агент 5 + Агент 6 Approver) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=

# --- Telegram: user account для Агента 6 (Telethon) ---
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+7

# --- Bitrix24 ---
# Входящий вебхук: Bitrix24 → Настройки → Разработчикам → Входящие вебхуки
BITRIX24_WEBHOOK_URL=

# --- Email / IMAP (папка с тендерами: Яндекс.Почта, Gmail или другой IMAP) ---
# Для Яндекс.Почты: IMAP_HOST=imap.yandex.ru, IMAP_PORT=993.
# GMAIL_USER и GMAIL_APP_PASSWORD оставлены как старые имена переменных:
# сюда пишем email почты и пароль приложения от этой почты.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TENDER_FOLDER=тендеры

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL ---
DATABASE_URL=postgresql://leadengine:password@localhost:5432/leadengine

# --- Прокси (для Агента 6, мобильный) ---
# Формат: socks5://user:pass@host:port
PROXY_URL=

# --- Avito API ---
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

# --- Режим работы ---
# debug — подробные логи, approver всегда спрашивает
# production — нормальный режим
APP_ENV=debug

# --- Agent 4 Publisher (контент-движок) ---
# OpenRouter — альтернативный LLM provider и текстовые LLM для Agent 4.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=VPP Lead Engine
# OpenAI — DALL-E 3 для иллюстраций
OPENAI_API_KEY=
# ElevenLabs — голосовая озвучка
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Replicate — Luma Ray и видео-модели
REPLICATE_API_TOKEN=
# Telegram бот публикации (отдельный от уведомительного TELEGRAM_BOT_TOKEN)
PUBLISHER_TELEGRAM_BOT_TOKEN=
PUBLISHER_TELEGRAM_CHANNEL_ID=
# Postmypost — публикация в Instagram
POSTMYPOST_TOKEN=
POSTMYPOST_PROJECT_ID=
POSTMYPOST_INSTAGRAM_ACCOUNT_ID=

# MAX — публикация в канал/чат через официальный Bot API
# Токен создаётся в MAX при создании бота. Не коммитить реальное значение.
MAX_BOT_TOKEN=
# ID чата/канала, куда бот имеет право отправлять сообщения.
MAX_CHAT_ID=
# Обычно менять не нужно.
MAX_API_BASE_URL=https://platform-api.max.ru
