# ============================================================
#  Lead Engine — ООО «Вектор Плюс-Про»
#  Скопируй этот файл в .env и заполни своими значениями
# ============================================================

# --- LLM router: можно переключать мозг системы без переписывания агентов ---
# anthropic — прямой Claude API; openrouter — модели через OpenRouter; dry_run — без внешнего LLM.
LLM_PROVIDER=anthropic
# Анализ: скоринг лидов, релевантность, детектор интереса. Здесь нужна дешевая модель.
LLM_MODEL_ANALYSIS=claude-haiku-4-5-20251001
# Ответы: первое сообщение, оффер, диалог. Здесь нужна более качественная модель.
LLM_MODEL_REPLY=claude-sonnet-4-6
# Контент Agent 4 через OpenRouter. Для теста можно поставить openrouter/free.
LLM_MODEL_CONTENT=anthropic/claude-3.7-sonnet
# Для LLM_PROVIDER=openrouter нужны model ID в формате provider/model:
# LLM_MODEL_ANALYSIS=openai/gpt-4o
# LLM_MODEL_REPLY=openai/gpt-4o
# LLM_MODEL_CONTENT=openai/gpt-4o

# --- Claude / Anthropic API ---
ANTHROPIC_API_KEY=

# --- Telegram: бот уведомлений менеджеру (Агент 5 + Агент 6 Approver) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=

# --- Telegram: user account для Агента 6 (Telethon) ---
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+7

# --- Bitrix24 ---
# Входящий вебхук: Bitrix24 → Настройки → Разработчикам → Входящие вебхуки
BITRIX24_WEBHOOK_URL=

# --- Email / IMAP (папка с тендерами: Яндекс.Почта, Gmail или другой IMAP) ---
# Для Яндекс.Почты: IMAP_HOST=imap.yandex.ru, IMAP_PORT=993.
# GMAIL_USER и GMAIL_APP_PASSWORD оставлены как старые имена переменных:
# сюда пишем email почты и пароль приложения от этой почты.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TENDER_FOLDER=тендеры

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL ---
DATABASE_URL=postgresql://leadengine:password@localhost:5432/leadengine

# --- Прокси (для Агента 6, мобильный) ---
# Формат: socks5://user:pass@host:port
PROXY_URL=

# --- Avito API ---
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

# --- Режим работы ---
# debug — подробные логи, approver всегда спрашивает
# production — нормальный режим
APP_ENV=debug

# --- Agent 4 Publisher (контент-движок) ---
# OpenRouter — альтернативный LLM provider и текстовые LLM для Agent 4.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=VPP Lead Engine
# OpenAI — DALL-E 3 для иллюстраций
OPENAI_API_KEY=
# ElevenLabs — голосовая озвучка
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Replicate — Luma Ray и видео-модели
REPLICATE_API_TOKEN=
# Telegram бот публикации (отдельный от уведомительного TELEGRAM_BOT_TOKEN)
PUBLISHER_TELEGRAM_BOT_TOKEN=
PUBLISHER_TELEGRAM_CHANNEL_ID=
# Postmypost — публикация в Instagram
POSTMYPOST_TOKEN=
POSTMYPOST_PROJECT_ID=
POSTMYPOST_INSTAGRAM_ACCOUNT_ID=

# MAX — публикация в канал/чат через официальный Bot API
# Токен создаётся в MAX при создании бота. Не коммитить реальное значение.
MAX_BOT_TOKEN=
# ID чата/канала, куда бот имеет право отправлять сообщения.
MAX_CHAT_ID=
# Обычно менять не нужно.
MAX_API_BASE_URL=https://platform-api.max.ru
